# Orvix Configuration — Generated by installer
# Edit this file after installation to customize settings

server:
  host: "0.0.0.0"
  port: 80
  admin_port: 8080
  admin_ui_dir: /usr/share/orvix/admin
  webmail_ui_dir: /usr/share/orvix/webmail
  read_timeout: 60s
  write_timeout: 60s
  idle_timeout: 120s
  body_limit: 52428800
  # Hostnames the operator points their DNS A records at.
  # The installer writes these as admin.<primary_domain>,
  # webmail.<primary_domain>, and mail.<primary_domain>.
  # Leave empty in dev / docker so the router falls back to
  # the request Host header.
  admin_host: ""
  webmail_host: ""
  mail_host: ""
  # CORS allowlist. The installer replaces this list with
  # the operator's admin + webmail + mail hostnames. Localhost
  # entries are kept for dev-mode testing.
  allowed_origins:
    - "http://localhost:3000"
    - "http://localhost:3001"
  # Reverse-proxy trust list. The installer writes 127.0.0.1
  # and ::1 here so Caddy's X-Forwarded-* headers are
  # honoured and the rate limiter / IP-allowlist see the
  # client IP instead of the loopback.
  trusted_proxies:
    - "127.0.0.1"
    - "::1"

database:
  driver: sqlite
  sqlite_path: /var/lib/orvix/orvix.db
  # PostgreSQL example (uncomment to use):
  # driver: postgres
  # host: localhost
  # port: 5432
  # user: orvix
  # password: CHANGEME
  # dbname: orvix
  # sslmode: disable

redis:
  host: 127.0.0.1
  port: 6379

outbound:
  # Prefer IPv4 for outbound SMTP while preserving IPv6 as
  # fallback after temporary IPv4 network failures.
  prefer_ipv4: true

coremail:
  enabled: true
  hostname: mail.example.com
  data_path: /var/lib/orvix/coremail
  smtp_host: 0.0.0.0
  smtp_port: 25
  imap_host: 0.0.0.0
  imap_port: 143
  pop3_host: 0.0.0.0
  pop3_port: 110
  jmap_host: 0.0.0.0
  jmap_port: 8081
  require_tls_for_auth: true
  license_file_path: /etc/orvix/license.json
  license_authority_cache_path: /var/lib/orvix/license-cache.json

auth:
  jwt_access_ttl: 15m
  jwt_refresh_ttl: 720h
  password_min_len: 8
  argon2_time: 3
  argon2_memory: 65536
  argon2_threads: 4
  login_rate_limit: 5
  rate_window: 15m
  # Domain attribute set on every auth cookie. The installer
  # writes ".parent_domain" so the access_token cookie is
  # sent to both admin.<parent> and webmail.<parent> (single
  # sign-on across subdomains). Leave empty in dev / docker.
  cookie_domain: ""

logging:
  level: info
  format: json
  output: stdout
  log_dir: /var/log/orvix

metrics:
  enabled: true
  path: /metrics

update:
  channel: stable
  auto_apply: false
  backup_before: true

clamav:
  host: localhost
  port: 3310

backup:
  dir: /var/backups/orvix/
  retention_count: 10
