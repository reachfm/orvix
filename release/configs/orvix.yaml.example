# Orvix Configuration — Generated by installer
# Edit this file after installation to customize settings

server:
  host: "0.0.0.0"
  port: 80
  admin_port: 8080
  admin_ui_dir: /usr/share/orvix/admin
  webmail_ui_dir: /usr/share/orvix/webmail
  read_timeout: 60s
  write_timeout: 60s
  idle_timeout: 120s
  body_limit: 52428800
  # Hostnames the operator points their DNS A records at.
  # The installer writes these as admin.<primary_domain>,
  # webmail.<primary_domain>, and mail.<primary_domain>.
  # Leave empty in dev / docker so the router falls back to
  # the request Host header.
  admin_host: ""
  webmail_host: ""
  mail_host: ""
  # CORS allowlist. The installer replaces this list with
  # the operator's admin + webmail + mail hostnames. Localhost
  # entries are kept for dev-mode testing.
  allowed_origins:
    - "http://localhost:3000"
    - "http://localhost:3001"
  # Reverse-proxy trust list. The installer writes 127.0.0.1
  # and ::1 here so Caddy's X-Forwarded-* headers are
  # honoured and the rate limiter / IP-allowlist see the
  # client IP instead of the loopback.
  trusted_proxies:
    - "127.0.0.1"
    - "::1"

database:
  driver: sqlite
  sqlite_path: /var/lib/orvix/orvix.db
  # PostgreSQL example (uncomment to use):
  # driver: postgres
  # host: localhost
  # port: 5432
  # user: orvix
  # password: CHANGEME
  # dbname: orvix
  # sslmode: disable

redis:
  host: 127.0.0.1
  port: 6379

outbound:
  # Prefer IPv4 for outbound SMTP while preserving IPv6 as
  # fallback after temporary IPv4 network failures.
  prefer_ipv4: true

coremail:
  enabled: true
  hostname: mail.example.com
  data_path: /var/lib/orvix/coremail
  smtp_host: 0.0.0.0
  smtp_port: 25
  # Submission (port 587) for authenticated mail client submission.
  # STARTTLS is advertised and REQUIRED before AUTH. Do not enable
  # submission until tls_cert_file and tls_key_file point at a real
  # PEM-encoded certificate and private key (paths are operator-
  # supplied — the installer does not assume Caddy/Let's Encrypt).
  # If submission_enabled=true but the cert/key is missing or fails
  # to load, the listener stays DOWN and the admin dashboard shows
  # "disabled: TLS certificate/key not configured" or "disabled:
  # TLS certificate/key failed to load (<reason>)".
  submission_enabled: false
  submission_host: 0.0.0.0
  submission_port: 587
  # SMTPS (port 465, implicit TLS) — NOT YET IMPLEMENTED.
  # Keep disabled until full SMTPS support is available.
  smtps_enabled: false
  smtps_host: 0.0.0.0
  smtps_port: 465
  imap_host: 0.0.0.0
  imap_port: 143
  pop3_host: 0.0.0.0
  pop3_port: 110
  jmap_host: 0.0.0.0
  jmap_port: 8081
  # SMTP TLS certificate / key. Used for STARTTLS on port 25
  # (optional) and REQUIRED for port 587 submission. Provide
  # absolute paths to PEM-encoded files. The runtime never starts
  # an unusable plaintext submission listener — if these are set
  # but invalid, the listener is skipped with a clear log message.
  tls_cert_file: ""
  tls_key_file: ""
  require_tls_for_auth: true
  license_file_path: /etc/orvix/license.json
  license_authority_cache_path: /var/lib/orvix/license-cache.json

  # Web Push (RFC 8030 / RFC 8291) VAPID keys.
  #
  # VAPID is the "Voluntary Application Server Identification"
  # scheme that lets a browser push service (FCM, Mozilla
  # autopush, Apple Safari) verify that push notifications for
  # a given application genuinely come from the operator's
  # server. The runtime signs a short-lived JWT with the VAPID
  # private key on every push request; the public key is sent
  # to the browser so the push service can verify the signature.
  #
  # ────────────────────────────────────────────────────────────
  # Recommended production path (preferred)
  # ────────────────────────────────────────────────────────────
  #
  #   sudo /usr/share/orvix/scripts/generate-vapid-keys.sh \
  #       --write --subject mailto:admin@<primary-domain>
  #   sudo systemctl restart orvix
  #
  # --write (the default safe behaviour) does NOT print the
  # private key to the terminal. Instead it:
  #
  #   * writes /etc/orvix/vapid_private.key with mode 0600
  #     owned by root:root,
  #   * writes the public key into coremail.vapid_public_key
  #     in /etc/orvix/orvix.yaml,
  #   * records the file path in
  #     coremail.vapid_private_key_file, and
  #   * removes any pre-existing inline
  #     coremail.vapid_private_key value (avoids the
  #     "which value wins?" trap).
  #
  # The runtime reads the private key from the file at boot.
  # The key content never appears in the YAML, the systemd
  # unit EnvironmentFile, the process environment, or logs.
  #
  # ────────────────────────────────────────────────────────────
  # Field reference (these names match the config loader in
  # internal/config/config.go exactly)
  # ────────────────────────────────────────────────────────────
  #
  #   coremail.vapid_public_key        — required for push to
  #                                       function. URL-safe base64
  #                                       (no padding), 86 chars.
  #   coremail.vapid_private_key       — inline private key.
  #                                       PREFER vapid_private_key_file
  #                                       instead. Used only when
  #                                       vapid_private_key_file is
  #                                       empty AND the operator
  #                                       explicitly opts into an
  #                                       inline setup.
  #   coremail.vapid_private_key_file  — path to a 0600 root-owned
  #                                       file containing the private
  #                                       key. Preferred.
  #   coremail.vapid_subject           — contact URL (mailto: or
  #                                       https:) the push service
  #                                       uses to reach the operator
  #                                       on abuse reports. Required
  #                                       by RFC 8292. Defaults to
  #                                       "mailto:admin@<webmail_host>"
  #                                       when empty.
  #
  # ────────────────────────────────────────────────────────────
  # Environment-variable overrides (containers / CI)
  # ────────────────────────────────────────────────────────────
  #
  # The viper loader reads these after the YAML file so they
  # win. Use them for container / systemd drop-in overrides;
  # the installer / setup-https.sh workflow above is the
  # recommended path for a bare-metal install.
  #
  #   ORVIX_COREMAIL_VAPID_PUBLIC_KEY
  #   ORVIX_COREMAIL_VAPID_PRIVATE_KEY
  #   ORVIX_COREMAIL_VAPID_PRIVATE_KEY_FILE
  #   ORVIX_COREMAIL_VAPID_SUBJECT
  #
  # ────────────────────────────────────────────────────────────
  # When push is disabled
  # ────────────────────────────────────────────────────────────
  #
  # If vapid_public_key OR vapid_private_key is empty, browser
  # push is disabled and the webmail Settings → Notifications
  # panel shows "Push is disabled by the server operator".
  # The delivery worker silently skips push calls in that
  # state, so leaving the fields empty is safe — no startup
  # failure, no delivery disruption.
  #
  # ────────────────────────────────────────────────────────────
  # Manual one-time capture (--print-private-key)
  # ────────────────────────────────────────────────────────────
  #
  #   sudo /usr/share/orvix/scripts/generate-vapid-keys.sh \
  #       --print-private-key
  #
  # This prints the private key to stdout exactly once. It is
  # the only operator path that exposes the private key to a
  # terminal. Use it ONLY when:
  #
  #   * you need to paste the key into a managed secret
  #     store (Vault, AWS Secrets Manager, GCP Secret Manager),
  #     OR
  #   * you are migrating from an inline
  #     coremail.vapid_private_key to the file-based path
  #     and need to capture the existing value before
  #     deleting it from YAML.
  #
  # Do NOT use --print-private-key on a shared terminal,
  # inside `script(1)`, or with output piped to a file that
  # is not itself 0600 root-owned. The script will refuse
  # the flag when --write is also set, so accidental
  # disclosure during a normal install is impossible.
  vapid_public_key: ""
  vapid_private_key: ""
  vapid_private_key_file: ""
  vapid_subject: "mailto:admin@example.com"

auth:
  jwt_access_ttl: 15m
  jwt_refresh_ttl: 720h
  password_min_len: 8
  argon2_time: 3
  argon2_memory: 65536
  argon2_threads: 4
  login_rate_limit: 5
  rate_window: 15m
  # Domain attribute set on every auth cookie. The installer
  # writes ".parent_domain" so the access_token cookie is
  # sent to both admin.<parent> and webmail.<parent> (single
  # sign-on across subdomains). Leave empty in dev / docker.
  cookie_domain: ""

logging:
  level: info
  format: json
  output: stdout
  log_dir: /var/log/orvix

metrics:
  enabled: true
  path: /metrics

update:
  channel: stable
  auto_apply: false
  backup_before: true

clamav:
  host: localhost
  port: 3310

backup:
  dir: /var/backups/orvix/
  retention_count: 10
