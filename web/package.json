{
  "name": "orvixem-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev:admin": "vite --config admin/vite.config.ts",
    "dev:webmail": "vite --config webmail/vite.config.ts",
    "dev:portal": "vite --config portal/vite.config.ts",
    "build:admin": "cd admin && npx tsc --noEmit && npx vite build --config vite.config.ts",
    "build:webmail": "cd webmail && npx tsc --noEmit && npx vite build --config vite.config.ts",
    "build:portal": "cd portal && npx tsc --noEmit && npx vite build --config vite.config.ts",
    "build": "npm run build:admin && npm run build:webmail && npm run build:portal",
    "preview:admin": "vite preview --config admin/vite.config.ts",
    "preview:webmail": "vite preview --config webmail/vite.config.ts",
    "preview:portal": "vite preview --config portal/vite.config.ts"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.0",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.0.0",
    "@tanstack/react-virtual": "^3.11.0",
    "@tiptap/extension-placeholder": "^3.26.0",
    "@tiptap/extension-underline": "^3.26.0",
    "@tiptap/react": "^3.26.0",
    "@tiptap/starter-kit": "^3.26.0",
    "clsx": "^2.1.0",
    "i18next": "^24.0.0",
    "lucide-react": "^0.400.0",
    "motion": "^11.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.0.0",
    "react-router-dom": "^7.0.0",
    "recharts": "^2.15.0",
    "tailwind-merge": "^2.6.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
